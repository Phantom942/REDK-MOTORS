<div class="cta-sticky" aria-label="Actions rapides">
  <div class="cta-sticky__row">
    <a href="tel:{{ site.phone }}" class="cta-sticky__btn cta-sticky__btn--call" aria-label="Appeler RED-K MOTORS au {{ site.phoneDisplay }}" data-track="click_call" data-track-pos="sticky">📞 Appeler</a>
    <a href="{{ site.whatsappUrl }}" class="cta-sticky__btn cta-sticky__btn--whatsapp" target="_blank" rel="noopener noreferrer" data-track="click_whatsapp" data-track-pos="sticky">💬 WhatsApp</a>
  </div>
</div>
