{% if exemple.isGeneric %}
  {% set modelLabel = "votre véhicule" %}
  {% set breadcrumbLabel = exemple.searchQuery | default(exemple.serviceLabel) %}
  {% set kicker = "Guide prix · Tous modèles · Ivry (94)" %}
  {% set heroTitle = exemple.heroTitle | default("Prix " ~ (exemple.shortService or exemple.serviceLabel) ~ " · tous modèles") %}
  {% set heroLead = exemple.problemLead | default(description) %}
  {% set compareIntro = "Exemple de prix indicatif à Ivry — citadine, compacte ou SUV (" ~ exemple.yearRange ~ "). Le montant exact dépend du véhicule après inspection." %}
  {% set specificsTitle = "Points de vigilance avant intervention" %}
  {% set relatedTitle = "Exemples par modèle" %}
{% else %}
  {% set modelLabel = exemple.brand ~ " " ~ exemple.model %}
  {% set breadcrumbLabel = modelLabel %}
  {% set kicker = "Guide prix · " ~ exemple.brand %}
  {% set heroTitle = "Prix " ~ (exemple.shortService or exemple.serviceLabel) ~ " " ~ modelLabel %}
  {% set heroLead = description %}
  {% set compareIntro = "Exemple de prix indicatif pour une <strong>" ~ modelLabel ~ "</strong> (" ~ exemple.yearRange ~ ")." %}
  {% set specificsTitle = "À savoir sur " ~ modelLabel %}
  {% set relatedTitle = "Même prestation, autre modèle" %}
{% endif %}

<nav class="breadcrumb breadcrumb--compact" aria-label="Fil d'Ariane">
  <div class="container">
    <ol>
      {% for item in breadcrumbTrail %}
      <li>
        {% if item.current %}
        <span aria-current="page">{{ item.label }}</span>
        {% else %}
        <a href="{{ item.url }}">{{ item.label }}</a>
        {% endif %}
      </li>
      {% endfor %}
    </ol>
  </div>
</nav>

<article class="exemple-prix-article">
  <header class="exemple-prix-hero">
    <div class="container exemple-prix-hero__inner">
      <p class="section-kicker">{{ kicker }}</p>
      <h1>{{ heroTitle }}</h1>
      <div class="exemple-prix-hero__chips" aria-label="Informations véhicule">
        <span class="exemple-prix-chip">{{ exemple.yearRange }}</span>
        <span class="exemple-prix-chip">Ivry-sur-Seine (94)</span>
        <span class="exemple-prix-chip">Diagnostic offert</span>
      </div>
      <p class="exemple-prix-hero__lead">{{ heroLead }}</p>
      {% if exemple.isGeneric %}
      <p class="exemple-model-intro">
        Guide comparatif tous modèles (citadine à SUV) — fourchette indicative à Ivry.
        <a href="/tarifs/">Grille tarifaire complète</a> · <a href="/exemples/">Tous les guides prix</a>.
      </p>
      {% else %}
      <p class="exemple-model-intro">
        Exemple indicatif pour une <strong>{{ modelLabel }}</strong> ({{ exemple.yearRange }}) à Ivry-sur-Seine.
        Le montant exact dépend de l'état du véhicule après inspection — voir aussi la
        <a href="/tarifs/">grille tarifaire complète</a>
        {% if exemple.modelSlug %}
        · <a href="/exemples/modeles/{{ exemple.modelSlug }}/">toutes les prestations {{ modelLabel }}</a>
        {% endif %}.
      </p>
      {% endif %}
      <p class="exemple-prix-hero__actions">
        <a href="tel:{{ site.phone }}" class="btn btn--primary" data-track="click_call" data-track-pos="exemple_prix_hero">Devis gratuit · {{ site.phoneDisplayCompact }}</a>
        <a href="{{ site.whatsappUrl }}" class="btn btn--secondary" target="_blank" rel="noopener noreferrer" data-track="click_whatsapp" data-track-pos="exemple_prix_hero">WhatsApp</a>
      </p>
    </div>
  </header>

  {% include "blog-direct-answer.njk" %}

  <div class="exemple-prix-body">
    <div class="container">
      {% if exemple.painPoints and exemple.painPoints.length %}
      <section class="exemple-pain" aria-labelledby="exemple-pain-title">
        <p class="section-kicker">Le problème</p>
        <h2 id="exemple-pain-title">{{ exemple.problemTitle }}</h2>
        {% if exemple.problemLead and not exemple.isGeneric %}
        <p class="exemple-pain__lead">Sur une <strong>{{ modelLabel }}</strong> comme sur la plupart des véhicules : {{ exemple.problemLead }}</p>
        {% endif %}
        <ul class="exemple-pain__list">
          {% for point in exemple.painPoints %}
          <li class="exemple-pain__item">
            <span class="exemple-pain__icon" aria-hidden="true">!</span>
            <span>{{ point }}</span>
          </li>
          {% endfor %}
        </ul>
      </section>

      <section class="exemple-solution" aria-labelledby="exemple-solution-title">
        <p class="section-kicker">La solution</p>
        <h2 id="exemple-solution-title">{{ exemple.solutionTitle }}</h2>
        <p class="exemple-solution__lead">{{ exemple.solutionLead }}</p>
        <p class="exemple-solution__cta">
          <a href="tel:{{ site.phone }}" class="btn btn--primary" data-track="click_call" data-track-pos="exemple_prix_solution">Appeler · {{ site.phoneDisplayCompact }}</a>
          <a href="{{ site.whatsappUrl }}" class="btn btn--secondary" target="_blank" rel="noopener noreferrer" data-track="click_whatsapp" data-track-pos="exemple_prix_solution">WhatsApp</a>
        </p>
      </section>
      {% endif %}

      <section class="exemple-compare" aria-labelledby="exemple-compare-title">
        <p class="section-kicker">Exemple de prix</p>
        <h2 id="exemple-compare-title">{{ exemple.searchQuery }} : combien ça coûte ?</h2>
        <p class="exemple-compare__intro">
          {{ compareIntro | safe }}
        </p>

        <div class="exemple-compare__grid">
          <article class="exemple-compare__card exemple-compare__card--redk">
            <span class="exemple-compare__badge">Exemple chez nous · Ivry</span>
            <p class="exemple-compare__price">{{ exemple.redkPrice }}</p>
            {% if exemple.redkHighlight %}
            <p class="exemple-compare__highlight">{{ exemple.redkHighlight }}</p>
            {% endif %}
            <p class="exemple-compare__note">{{ exemple.redkNote }}</p>
            <a href="{{ exemple.serviceUrl }}" class="btn btn--primary exemple-compare__cta">Voir la prestation</a>
          </article>

          <article class="exemple-compare__card exemple-compare__card--network">
            <span class="exemple-compare__label">Ailleurs, en moyenne</span>
            <p class="exemple-compare__price">{{ exemple.networkPrice }}</p>
            <p class="exemple-compare__note">{{ exemple.networkNote }}</p>
          </article>
        </div>

        <p class="exemple-compare__disclaimer">
          Montants indicatifs à titre d'exemple — le prix exact dépend du véhicule après inspection à l'atelier.
          <a href="/tarifs/">Grille tarifaire complète</a>
          {% if genericExemple and not exemple.isGeneric %}
          · <a href="/exemples/{{ genericExemple.slug }}/">Guide {{ exemple.shortService or exemple.serviceLabel }} tous modèles</a>
          {% endif %}
        </p>
      </section>

      <section class="exemple-process" aria-labelledby="exemple-process-title">
        <h2 id="exemple-process-title">Comment ça se passe à l'atelier</h2>
        <ol class="exemple-process__list">
          <li><strong>Contact</strong> — appel ou WhatsApp, photos utiles pour un premier avis.</li>
          <li><strong>Inspection</strong> — diagnostic offert, explication claire avant devis.</li>
          <li><strong>Devis ferme</strong> — vous validez seulement si le montant vous convient.</li>
          <li><strong>Intervention</strong> — lun–sam 9h–19h, 9 rue Michelet, Ivry-sur-Seine.</li>
        </ol>
      </section>

      <aside class="exemple-tarifs-strip" aria-label="Liens tarifs et prestation">
        <div class="exemple-tarifs-strip__inner">
          <a href="/tarifs/" class="exemple-tarifs-strip__link" data-track="click_tarifs" data-track-pos="exemple_prix_strip">Grille tarifaire →</a>
          <a href="/exemples/" class="exemple-tarifs-strip__link" data-track="click_tarifs" data-track-pos="exemple_prix_strip_guides">Tous les guides prix →</a>
          <a href="{{ exemple.serviceUrl }}" class="exemple-tarifs-strip__link" data-track="click_service" data-track-pos="exemple_prix_strip">Prestation atelier →</a>
          {% if not exemple.isGeneric and exemple.modelSlug %}
          <a href="/exemples/modeles/{{ exemple.modelSlug }}/" class="exemple-tarifs-strip__link" data-track="click_price_example" data-track-pos="exemple_prix_strip_modele">Toutes les prestations {{ exemple.brand }} {{ exemple.model }} →</a>
          {% endif %}
        </div>
      </aside>

      {% if exemple.specifics and exemple.specifics.length %}
      <section class="exemple-specifics" aria-labelledby="exemple-specifics-title">
        <h2 id="exemple-specifics-title">{{ specificsTitle }}</h2>
        <ul class="exemple-specifics__list">
          {% for point in exemple.specifics %}
          <li class="exemple-specifics__item">
            <span class="exemple-specifics__icon" aria-hidden="true">✓</span>
            <span>{{ point }}</span>
          </li>
          {% endfor %}
        </ul>
      </section>
      {% endif %}

      <section class="exemple-atelier" aria-labelledby="exemple-atelier-title">
        <div class="exemple-atelier__inner">
          <div>
            <h2 id="exemple-atelier-title">{{ (exemple.shortService or exemple.serviceLabel) | capitalize }} à Ivry-sur-Seine</h2>
            <p>
              RED-K MOTORS, 9 rue Michelet, 94200 Ivry-sur-Seine — accessible depuis Vitry, Villejuif, Paris 13 et le Val-de-Marne.
              Lun–sam 9h–19h. <strong>Diagnostic offert à chaque intervention.</strong>
            </p>
          </div>
          <p class="exemple-atelier__actions">
            <a href="tel:{{ site.phone }}" class="btn btn--primary" data-track="click_call" data-track-pos="exemple_prix">Appeler le {{ site.phoneDisplayCompact }}</a>
            <a href="{{ site.whatsappUrl }}" class="btn btn--secondary" target="_blank" rel="noopener noreferrer" data-track="click_whatsapp" data-track-pos="exemple_prix">WhatsApp</a>
          </p>
        </div>
      </section>

      {% if contextLinks and contextLinks.length %}
      <nav class="exemple-prix-crosslinks" aria-label="Pages utiles">
        <h2 class="exemple-prix-crosslinks__title">À consulter aussi</h2>
        <ul class="exemple-prix-crosslinks__list">
          {% for link in contextLinks %}
          <li><a href="{{ link.url }}">{{ link.label }}</a></li>
          {% endfor %}
        </ul>
      </nav>
      {% endif %}

      {% if siblingServices and siblingServices.length %}
      <section class="exemple-prix-related" aria-labelledby="exemple-sibling-title">
        <h2 id="exemple-sibling-title">Autres prestations {{ modelLabel }}</h2>
        <ul class="exemple-prix-related__grid">
          {% for item in siblingServices %}
          <li>
            <a class="exemple-prix-related__link" href="{{ item.url }}">
              <span class="exemple-prix-related__model">{{ item.label }}</span>
            </a>
          </li>
          {% endfor %}
        </ul>
      </section>
      {% endif %}

      {% if genericExemple and not exemple.isGeneric %}
      <p class="exemple-prix-generic-link">
        <a href="/exemples/{{ genericExemple.slug }}/">Voir le guide prix {{ exemple.shortService or exemple.serviceLabel }} — tous modèles</a>
      </p>
      {% endif %}

      {% if relatedExemples and relatedExemples.length %}
      <section class="exemple-prix-related" aria-labelledby="exemple-related-title">
        <h2 id="exemple-related-title">{{ relatedTitle }}</h2>
        <ul class="exemple-prix-related__grid">
          {% for item in relatedExemples %}
          <li>
            <a class="exemple-prix-related__link" href="/exemples/{{ item.slug }}/">
              {% if item.anchor %}
              <span class="exemple-prix-related__model">{{ item.anchor }}</span>
              {% else %}
              <span class="exemple-prix-related__brand">{{ item.brand }}</span>
              <span class="exemple-prix-related__model">{{ item.model }}</span>
              {% endif %}
            </a>
          </li>
          {% endfor %}
        </ul>
      </section>
      {% endif %}
    </div>
  </div>
</article>

{% set contactVariant = 'footer' %}
{% set contactTitle = 'Un devis pour votre véhicule ?' %}
{% set contactLead = 'Inspection gratuite à Ivry — devis ferme avant toute intervention.' %}
{% include "conversion-contact.njk" %}
