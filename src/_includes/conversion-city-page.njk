{% if not h1 and heroTitle %}
  {% set h1 = heroTitle %}
{% endif %}
{% if not heroKickerText and heroKicker %}
  {% set heroKickerText = heroKicker %}
{% endif %}
{% if not heroDescription and heroDesc %}
  {% set heroDescription = heroDesc %}
{% endif %}
{% if not introText %}
  {% set introText = heroDescription | default("Garage à Ivry-sur-Seine — devis gratuit.") %}
{% endif %}
{% if not services %}
  {% set services = [
    { title: "Mécanique & diagnostic", url: "/mecanique/" },
    { title: "Entretien & vidange", url: "/entretien/" },
    { title: "Freins & pneus", url: "/freins/" },
    { title: "Carrosserie & pare-brise", url: "/carrosserie/" }
  ] %}
{% endif %}

{% set citySeo = pageKey | citySeoContent %}
{% if citySeo %}
  {% set lp = citySeo %}
  {% set lpId = pageKey %}
{% endif %}

{% include "local-seo-page.njk" %}
