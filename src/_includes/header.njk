<div class="scroll-progress" aria-hidden="true">
  <span class="scroll-progress__indicator"></span>
</div>
<a class="skip-link" href="#main">Aller au contenu principal</a>

<header class="main-header" role="banner">
  <div class="container main-header__inner">
    <a class="logo" href="/" aria-label="Accueil {{ site.name }}">
      <img class="logo__img" src="{{ '/assets/img/logo-redk-motors.png' | cacheBust }}" alt="Logo garage automobile RED-K MOTORS à Ivry-sur-Seine (94)" width="676" height="129" decoding="async" fetchpriority="high" />
    </a>
    <nav class="main-nav" aria-label="Navigation principale">
      {% include "nav-google-rating.njk" %}
      <ul class="main-nav__bar-links">
        {% for item in site.nav %}
          {% if item.navbar %}
            <li class="main-nav__bar-item{% if item.children %} main-nav__bar-item--has-sub{% if item.highlight %} main-nav__bar-item--pro{% endif %}{% for child in item.children %}{% if pageKey == child.key %} is-active{% endif %}{% endfor %}{% if item.activeKeys %}{% for activeKey in item.activeKeys %}{% if pageKey == activeKey %} is-active{% endif %}{% endfor %}{% endif %}{% endif %}">
              {% if item.children %}
                <button
                  type="button"
                  class="btn btn--primary main-nav__bar-link main-nav__bar-trigger{% if item.highlight %} main-nav__bar-trigger--pro{% endif %}"
                  aria-expanded="false"
                  aria-haspopup="true"
                  aria-controls="nav-bar-sub-{{ item.key }}"
                >
                  <span>{{ item.title }}</span>
                  <span class="main-nav__caret" aria-hidden="true">▾</span>
                </button>
                <div class="main-nav__bar-panel" id="nav-bar-sub-{{ item.key }}">
                  <div class="main-nav__bar-panel-inner">
                    <p class="main-nav__bar-panel-label">{{ item.title }}</p>
                    <ul class="main-nav__bar-sub" role="menu" aria-label="{{ item.title }}">
                      {% if item.hub %}
                      <li class="main-nav__bar-sub-item main-nav__bar-sub-item--hub" role="none">
                        <a href="{{ item.hub.url }}" role="menuitem" {% if pageKey == item.hub.key %}aria-current="page"{% endif %}>{{ item.hub.title }}</a>
                      </li>
                      {% endif %}
                      {% for child in item.children %}
                      <li class="main-nav__bar-sub-item" role="none">
                        <a href="{{ child.url }}" role="menuitem" {% if pageKey == child.key %}aria-current="page"{% endif %}>{{ child.title }}</a>
                      </li>
                      {% endfor %}
                    </ul>
                  </div>
                </div>
              {% elif item.hub %}
                <a
                  href="{{ item.hub.url }}"
                  class="btn btn--primary main-nav__bar-link"
                  {% if pageKey == item.hub.key %}aria-current="page"{% endif %}
                  {% if item.activeKeys %}{% for activeKey in item.activeKeys %}{% if pageKey == activeKey %}aria-current="page"{% endif %}{% endfor %}{% endif %}
                >{{ item.title }}</a>
              {% else %}
                <a
                  href="{{ item.url }}"
                  class="btn btn--primary main-nav__bar-link"
                  {% if pageKey == item.key %}aria-current="page"{% endif %}
                >{{ item.title }}</a>
              {% endif %}
            </li>
          {% endif %}
        {% endfor %}
      </ul>
      <a href="tel:{{ site.phone }}" class="btn btn--primary main-nav__phone" data-track="click_call" data-track-pos="header">{{ site.phoneDisplayCompact | default(site.phoneDisplay) }}</a>
      <button class="btn btn--primary main-nav__toggle" type="button" aria-expanded="false" aria-controls="primary-menu">
        <span class="sr-only">Ouvrir le menu</span>
        <span class="main-nav__toggle-label" aria-hidden="true">Menu</span>
        <span class="main-nav__bars" aria-hidden="true">
          <span class="main-nav__bar"></span>
          <span class="main-nav__bar"></span>
          <span class="main-nav__bar"></span>
        </span>
      </button>
      <div class="main-nav__backdrop" id="nav-backdrop" hidden aria-hidden="true"></div>
      <ul id="primary-menu">
        <li class="main-nav__item main-nav__item--mobile-call">
          <a href="tel:{{ site.phone }}" class="main-nav__mobile-call" data-track="click_call" data-track-pos="drawer">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 012.12 4.18 2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.362 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.338 1.85.573 2.81.7A2 2 0 0122 16.92z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            {{ site.phoneDisplay }}
          </a>
        </li>
        {% for item in site.nav %}
            <li class="main-nav__item{% if item.navbar %} main-nav__item--bar-fallback{% endif %}{% if item.children %} main-nav__item--has-sub{% if item.highlight %} main-nav__item--pro{% endif %}{% for child in item.children %}{% if pageKey == child.key %} is-active{% endif %}{% endfor %}{% if item.activeKeys %}{% for activeKey in item.activeKeys %}{% if pageKey == activeKey %} is-active{% endif %}{% endfor %}{% endif %}{% endif %}">
              {% if item.children %}
                <button
                  type="button"
                  class="main-nav__trigger{% if item.highlight %} main-nav__trigger--pro{% endif %}"
                  aria-expanded="false"
                  aria-haspopup="true"
                  aria-controls="nav-sub-{{ item.key }}"
                >
                  <span>{{ item.title }}</span>
                  <span class="main-nav__caret" aria-hidden="true">▾</span>
                </button>
                <ul id="nav-sub-{{ item.key }}" class="main-nav__sub" role="menu">
                  {% if item.hub %}
                  <li role="none">
                    <a href="{{ item.hub.url }}" role="menuitem" {% if pageKey == item.hub.key %}aria-current="page"{% endif %}>{{ item.hub.title }}</a>
                  </li>
                  {% endif %}
                  {% for child in item.children %}
                  <li role="none">
                    <a href="{{ child.url }}" role="menuitem" {% if pageKey == child.key %}aria-current="page"{% endif %}>{{ child.title }}</a>
                  </li>
                  {% endfor %}
                </ul>
              {% else %}
                <a href="{{ item.url }}" {% if pageKey == item.key %}aria-current="page"{% endif %}>{{ item.title }}</a>
              {% endif %}
            </li>
        {% endfor %}
      </ul>
    </nav>
  </div>
</header>
