<div class="scroll-progress" aria-hidden="true">
  <span class="scroll-progress__indicator"></span>
</div>
<a class="skip-link" href="#main">Aller au contenu principal</a>

<div class="top-bar">
  <div class="container top-bar__inner">
    <p class="top-bar__meta">
      <span class="top-bar__hours">{{ site.openingHours }}</span>
      <a class="top-bar__link" href="mailto:{{ site.email }}">{{ site.email }}</a>
      <a class="top-bar__link" href="https://www.google.com/maps?q=9+rue+Michelet+94200+Ivry-sur-Seine" target="_blank" rel="noopener noreferrer">{{ site.addressFull }}</a>
    </p>
    <div class="top-bar__actions">
      <a class="btn btn--ghost top-bar__cta-call" href="tel:{{ site.phone }}" aria-label="Appeler {{ site.name }} au {{ site.phoneDisplay }}" data-track="click_call" data-track-pos="header_top">
        <svg class="top-bar__cta-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 012.12 4.18 2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.362 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.338 1.85.573 2.81.7A2 2 0 0122 16.92z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Appeler
      </a>
      <a class="btn btn--ghost top-bar__cta-wa" href="{{ site.whatsappUrl }}" target="_blank" rel="noopener noreferrer" aria-label="Nous contacter sur WhatsApp" data-track="click_whatsapp" data-track-pos="header_top">WhatsApp</a>
    </div>
  </div>
</div>

<header class="main-header" role="banner">
  <div class="container main-header__inner">
    <a class="logo" href="/" aria-label="Accueil {{ site.name }}">
      <span class="logo__accent">RED-K</span> MOTORS
    </a>
    <nav class="main-nav" aria-label="Navigation principale">
      <button class="main-nav__toggle" type="button" aria-expanded="false" aria-controls="primary-menu">
        <span class="sr-only">Ouvrir le menu</span>
        ☰
      </button>
      <ul id="primary-menu">
        {% for item in site.nav %}
        <li>
          <a href="{{ item.url }}" {% if pageKey == item.key %}aria-current="page"{% endif %} aria-label="{{ item.title }}">
            {{ item.title }}
          </a>
        </li>
        {% endfor %}
      </ul>
    </nav>
  </div>
</header>
