<section class="hero {{ heroClass }}" {% if heroAria %}aria-labelledby="{{ heroAria }}"{% endif %}>
  <div class="hero__video-bg" aria-hidden="true" data-nosnippet>
    {# Remplacez hero-poster.jpg par une capture nette de votre atelier (1200×675 px recommandé, &lt; 150 Ko) #}
    <video
      class="hero__video-player"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      poster="/assets/posters/hero-poster.jpg"
      aria-label="Vidéo de présentation du garage RED-K MOTORS à Ivry-sur-Seine"
      disablePictureInPicture
      disableRemotePlayback
    >
      <source data-src="/assets/video/{{ videoSrc | replace('.mp4', '-mobile.mp4') }}" type="video/mp4" media="(max-width: 768px)" />
      <source data-src="/assets/video/{{ videoSrc }}" type="video/mp4" />
      Votre navigateur ne supporte pas la lecture de vidéos.
    </video>
  </div>
  <div class="hero__overlay" aria-hidden="true"></div>
  <div class="container hero__content">
    <div>
      {% if heroKicker %}<p class="hero__kicker">{{ heroKicker }}</p>{% endif %}
      {% if heroMeta %}<p class="hero__meta">{{ heroMeta }}</p>{% endif %}
      <h1 {% if heroAria %}id="{{ heroAria }}"{% endif %}>{{ heroTitle }}</h1>
      {% if heroDesc %}<p class="hero__lede">{{ heroDesc }}</p>{% endif %}
      {% if heroActions %}
      <div class="hero__actions{% if heroActionsCro %} hero__actions--cro{% endif %}">
        {{ heroActions | safe }}
      </div>
      {% endif %}
    </div>
  </div>
</section>
