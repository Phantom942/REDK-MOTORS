<section class="reviews-section" aria-labelledby="reviews-title" data-animate="slide-up">
  <div class="container">
    <header class="reviews-section__header">
      <h2 id="reviews-title" class="reviews-section__title">Avis Google</h2>
      <div
        class="reviews-section__rating"
        id="google-reviews-rating"
        role="group"
        aria-label="Note Google : {{ site.googleReviews.rating }} sur 5, {{ site.googleReviews.count }} avis"
        data-rating="{{ site.googleReviews.rating }}"
        data-count="{{ site.googleReviews.count }}"
      >
        <div class="reviews-section__score-wrap">
          <span class="reviews-section__score" id="google-reviews-score" aria-hidden="true">{{ site.googleReviews.rating }}.0</span>
          <div class="reviews-section__stars-main" id="google-reviews-stars" aria-hidden="true">
            {% for i in range(0, site.googleReviews.rating) %}<span class="reviews-section__star">★</span>{% endfor %}
          </div>
        </div>
        <div class="reviews-section__badge-google">
          <span class="reviews-section__google-mark">G</span>
          <span class="reviews-section__badge-text">
            <span class="reviews-section__badge-score" id="google-reviews-badge-score">{{ site.googleReviews.rating }}.0</span>
            <span class="reviews-section__badge-sep">/</span>
            <span class="reviews-section__badge-count" id="google-reviews-badge-count">{{ site.googleReviews.count }} avis</span>
          </span>
        </div>
      </div>
    </header>

    <div class="reviews-section__grid" id="google-reviews-grid">
      {% for review in googleReviews.reviews %}
      <article class="review-card">
        <div class="review-card__stars" role="img" aria-label="{{ review.rating }} sur 5 étoiles">
          <span aria-hidden="true">{% for i in range(0, review.rating) %}★{% endfor %}</span>
        </div>
        <p class="review-card__text">{{ review.text }}</p>
        <footer class="review-card__footer">
          <span class="review-card__name">{{ review.author }}</span>
          <span class="review-card__source">Google</span>
        </footer>
      </article>
      {% endfor %}
    </div>

    <p class="reviews-section__cta">
      <a href="{{ site.googleReviews.shareUrl }}" class="reviews-section__link" target="_blank" rel="noopener noreferrer">Voir tous les avis sur Google</a>
    </p>
  </div>
</section>
