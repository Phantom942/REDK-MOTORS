<section class="lead-strip" aria-label="Actions rapides">
  <div class="container lead-strip__inner">
    <p class="lead-strip__text">
      Devis rapide et clair en atelier.
      <strong>Appel prioritaire :</strong>
      <a href="tel:{{ site.phone }}" data-track="click_call_strip" data-track-pos="lead_strip">{{ site.phoneDisplay }}</a>
    </p>
    <div class="lead-strip__actions">
      <a class="btn btn--primary" href="/contact/" data-track="click_contact_strip" data-track-pos="lead_strip">Prendre rendez-vous</a>
      <a class="btn btn--secondary" href="{{ site.whatsappUrl }}" target="_blank" rel="noopener noreferrer" data-track="click_whatsapp_strip" data-track-pos="lead_strip">WhatsApp</a>
    </div>
  </div>
</section>
