<section class="blog-conversion-strip" aria-label="Contact atelier">
  <div class="container blog-conversion-strip__inner">
    <p class="blog-conversion-strip__title">Un doute sur votre véhicule ?</p>
    <p class="blog-conversion-strip__lead">Diagnostic et devis gratuit à Ivry-sur-Seine — lun–sam 9h–19h.</p>
    <p class="blog-conversion-strip__actions">
      <a href="tel:{{ site.phone }}" class="btn btn--primary" data-track="click_call" data-track-pos="blog_strip">Appeler {{ site.phoneDisplayCompact }}</a>
      <a href="{{ site.whatsappUrl }}" class="btn btn--secondary" target="_blank" rel="noopener noreferrer" data-track="click_whatsapp" data-track-pos="blog_strip">WhatsApp</a>
      <a href="/tarifs/" class="btn btn--secondary" data-track="click_tarifs" data-track-pos="blog_strip">Tarifs indicatifs</a>
    </p>
  </div>
</section>
