<div class="quick-quote" id="devis-rapide">
  <div class="quick-quote__header">
    <h3 class="quick-quote__title">Devis gratuit en 2 minutes</h3>
    <p class="quick-quote__sub">Décrivez votre besoin, on vous rappelle.</p>
  </div>
  <form
    class="form quick-quote__form"
    action="https://formsubmit.co/contact@redk-motors.me"
    method="post"
  >
    <input type="hidden" name="_next" value="https://redk-motors.me/merci/" />
    <input type="hidden" name="_subject" value="Demande de devis rapide - RED-K MOTORS" />

    <div class="form__group">
      <label for="qq-nom">Nom</label>
      <input
        id="qq-nom"
        name="nom"
        type="text"
        required
        autocomplete="name"
      />
    </div>
    <div class="form__group">
      <label for="qq-tel">Téléphone</label>
      <input
        id="qq-tel"
        name="telephone"
        type="tel"
        required
        autocomplete="tel"
      />
    </div>
    <div class="form__group">
      <label for="qq-service">Service</label>
      <select id="qq-service" name="service" required>
        <option value="" disabled selected>Choisissez un service</option>
        <option value="Mécanique">Mécanique</option>
        <option value="Carrosserie">Carrosserie</option>
        <option value="Entretien">Entretien</option>
        <option value="Vidange">Vidange</option>
        <option value="Freins">Freins</option>
        <option value="Diagnostic">Diagnostic</option>
        <option value="Pneumatiques">Pneumatiques</option>
        <option value="Autre">Autre</option>
      </select>
    </div>
    <div class="form__group form__group--full">
      <label for="qq-message">Message</label>
      <textarea
        id="qq-message"
        name="message"
        rows="2"
        placeholder="Décrivez votre besoin..."
      ></textarea>
    </div>
    <button type="submit" class="btn btn--primary quick-quote__submit">Envoyer ma demande</button>
    <p class="quick-quote__phone-alt">
      Ou appelez-nous :
      <a href="tel:{{ site.phone }}">{{ site.phoneDisplay }}</a>
    </p>
  </form>
</div>
