{% if lp.seoParagraphs and lp.seoParagraphs.length %}
<section class="service-focus service-focus--compact" aria-labelledby="{{ lpId }}-seo-text">
  <div class="container service-focus__inner">
    <div>
      {% if lp.seoTitle %}
      <h2 id="{{ lpId }}-seo-text">{{ lp.seoTitle }}</h2>
      {% endif %}
      {% for paragraph in lp.seoParagraphs %}
      <p>{{ paragraph }}</p>
      {% endfor %}
      {% if lp.seoProblems and lp.seoProblems.length %}
      <h3 class="service-focus__subhead">Problèmes fréquents traités en atelier</h3>
      <ul class="conversion-services__list service-focus__problem-list">
        {% for problem in lp.seoProblems %}
        <li>
          {% if problem.url %}
          <a href="{{ problem.url }}" class="conversion-services__link">{{ problem.text }}</a>
          {% else %}
          {{ problem.text }}
          {% endif %}
        </li>
        {% endfor %}
      </ul>
      {% endif %}
    </div>
  </div>
</section>
{% endif %}
