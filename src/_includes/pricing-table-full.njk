<div class="pricing-table-wrap">
  <table class="pricing-table">
    <caption class="sr-only">Grille de prix indicative RED-K MOTORS</caption>
    <thead>
      <tr>
        <th scope="col">Prestation</th>
        <th scope="col">À partir de / fourchette</th>
      </tr>
    </thead>
    <tbody>
      {% for row in pricingData.rows %}
      <tr>
        <th scope="row">
          {{ row.label }}
          {% if row.guideSlug %}
          <a
            href="/exemples/{{ row.guideSlug }}/"
            class="pricing-table__guide"
            data-track="click_price_example"
            data-track-pos="pricing_table"
            data-track-label="{{ row.guideSlug }}"
          >{{ row.guideLabel | default("Exemple détaillé") }} →</a>
          {% endif %}
        </th>
        <td>{{ row.priceHtml | safe }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
