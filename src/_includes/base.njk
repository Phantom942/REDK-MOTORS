<!DOCTYPE html>
<html lang="fr">
  <head>
    {% set defaultRobots = 'index, follow' %}
    {% if page and page.url %}
      {% set noindexRules = seoNoindex %}
      {% set forceIndex = false %}
      {% for allowedPath in noindexRules.indexablePaths %}
        {% if page.url == allowedPath %}
          {% set forceIndex = true %}
        {% endif %}
      {% endfor %}
      {% if not forceIndex %}
        {% for prefix in noindexRules.prefixes %}
          {% if prefix in page.url %}
            {% set defaultRobots = 'noindex, follow' %}
          {% endif %}
        {% endfor %}
      {% endif %}
    {% endif %}
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes, viewport-fit=cover" />
    <meta name="description" content="{{ description | default(site.description or 'Garage automobile RED-K MOTORS à Ivry-sur-Seine. Mécanique, carrosserie, entretien et pneumatiques.') }}" />
    <meta name="author" content="{{ site.name }}" />
    <meta name="robots" content="{{ robots | default(defaultRobots) }}" />
    <meta name="geo.region" content="{{ site.geo.region }}" />
    <meta name="geo.placename" content="{{ site.geo.placename }}" />
    <meta name="geo.position" content="{{ site.geo.position }}" />
    <meta name="ICBM" content="{{ site.geo.icbm }}" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="{{ ogType | default('website') }}" />
    <meta property="og:url" content="{{ site.url }}{{ page.url | default('/') | replace('/index.html','/') }}" />
    <meta property="og:site_name" content="Garage Automobile {{ site.name }}" />
    <meta property="og:locale" content="{{ site.locale }}" />
    <meta property="og:title" content="{{ ogTitle | default(title) | default(site.seoTitle) | default(site.name) }}" />
    <meta property="og:description" content="{{ ogDescription | default(description) | default(site.description) }}" />
    <meta property="og:image" content="{{ ogImage | default(site.ogImage) }}" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="{{ site.name }} - Garage mécanique et carrosserie Île-de-France" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="{{ twitterTitle | default(ogTitle) | default(title) | default(site.seoTitle) | default(site.name) }}" />
    <meta name="twitter:description" content="{{ twitterDescription | default(ogDescription) | default(description) | default(site.description) }}" />
    <meta name="twitter:image" content="{{ ogImage | default(site.ogImage) }}" />
    <meta name="twitter:image:alt" content="{{ site.name }} - Garage mécanique et carrosserie Île-de-France" />

    <!-- Favicon + PWA (PNG / ICO depuis logo-basique-carre, SVG en secours) -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" href="{{ '/favicon.svg' | cacheBust }}" type="image/svg+xml" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <title>{{ title | default(site.seoTitle) | default(site.name) }}</title>
    <link rel="canonical" href="{{ site.url }}{{ page.url | default('/') | replace('/index.html','/') }}" />
    <link rel="sitemap" type="application/xml" title="Sitemap" href="{{ site.url }}/sitemap.xml" />
    <script src="{{ '/assets/js/canonical-url.js' | cacheBust }}"></script>
    <link rel="alternate" type="text/plain" href="{{ site.url }}/llms.txt" title="LLM context (llms.txt)" />
    <link rel="alternate" type="text/plain" href="{{ site.url }}/ai.txt" title="AI discovery (ai.txt)" />

    {% set googleFontsUrl = "https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700;800&display=swap" %}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" href="{{ googleFontsUrl }}" as="style" />
    <link rel="stylesheet" href="{{ googleFontsUrl }}" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="{{ googleFontsUrl }}" /></noscript>
    <link rel="preload" href="{{ '/assets/css/styles.css' | cacheBust }}" as="style" fetchpriority="high" />
    <link rel="stylesheet" href="{{ '/assets/css/styles.css' | cacheBust }}" />
    <link rel="stylesheet" href="{{ '/assets/css/design-stitch.css' | cacheBust }}" />

    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="theme-color" content="#131317" />
    <meta name="msapplication-TileColor" content="#131317" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="mobile-web-app-capable" content="yes" />

    <!-- GTM chargé uniquement après consentement cookies (voir cookies.js) -->

    <!-- JSON-LD global (WebSite + AutoRepair + WebPage, une seule injection par page) -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "@id": "{{ site.url }}/#website",
          "name": "{{ site.seoTitle | default(site.name) }}",
          "url": "{{ site.url }}",
          "description": "{{ site.description | default('Garage automobile à Ivry-sur-Seine') }}",
          "publisher": { "@id": "https://redkmotors.fr/#business" },
          "inLanguage": "fr-FR",
          "potentialAction": {
            "@type": "SearchAction",
            "target": {
              "@type": "EntryPoint",
              "urlTemplate": "https://www.google.com/search?q=site:redkmotors.fr+{search_term_string}"
            },
            "query-input": "required name=search_term_string"
          }
        },
        {
          "@type": "ItemList",
          "@id": "{{ site.url }}/#primary-navigation",
          "name": "Pages principales",
          "itemListElement": {{ site.sitelinksHints | json | safe }}
        },
        {
          "@type": "WebPage",
          "@id": "{{ site.url }}{{ page.url | default('/') | replace('/index.html','/') }}#webpage",
          "url": "{{ site.url }}{{ page.url | default('/') | replace('/index.html','/') }}",
          "name": "{{ title | default(site.seoTitle) | default(site.name) }}",
          "description": "{{ description | default(site.description) }}",
          {% set freshnessDate = (lastReviewed or date) | dateToIso %}
          {% if freshnessDate %}
          "dateModified": "{{ freshnessDate }}",
          {% endif %}
          "isPartOf": { "@id": "{{ site.url }}/#website" },
          "about": { "@id": "https://redkmotors.fr/#business" },
          "inLanguage": "fr-FR",
          "speakable": {
            "@type": "SpeakableSpecification",
            "cssSelector": ["h1", "h2", ".hero__lede", ".hero__desc", ".direct-answer__lead", ".promesse__title", "meta[name='description']"]
          }
        },
        {{ (localBusinessSchema or localBusiness.schema) | json | safe }}
      ]
    }
    </script>

    {% if breadcrumb %}
    <!-- Breadcrumb Schema -->
    <script type="application/ld+json">
    {{ breadcrumb | json | safe }}
    </script>
    {% endif %}

    {% if faqSchema %}
    <!-- FAQ Schema -->
    <script type="application/ld+json">
    {{ faqSchema | json | safe }}
    </script>
    {% endif %}

    {% if articleSchema %}
    <!-- Article Schema (BlogPosting) -->
    <script type="application/ld+json">
    {{ articleSchema | json | safe }}
    </script>
    {% endif %}

    {% if offerSchema %}
    <script type="application/ld+json">
    {{ offerSchema | json | safe }}
    </script>
    {% endif %}

    {% if localServiceSchema %}
    <!-- JSON-LD Service (zone desservie) -->
    <script type="application/ld+json">
    {{ localServiceSchema | json | safe }}
    </script>
    {% endif %}

    {% if itemListSchema %}
    <script type="application/ld+json">
    {{ itemListSchema | json | safe }}
    </script>
    {% endif %}

    {% if howToSchema %}
    <script type="application/ld+json">
    {{ howToSchema | json | safe }}
    </script>
    {% endif %}

    {% if offerCatalogSchema %}
    <script type="application/ld+json">
    {{ offerCatalogSchema | json | safe }}
    </script>
    {% endif %}

    {% if contactPageSchema %}
    <script type="application/ld+json">
    {{ contactPageSchema | json | safe }}
    </script>
    {% endif %}

    {% if personSchema %}
    <script type="application/ld+json">
    {{ personSchema | json | safe }}
    </script>
    {% endif %}
  </head>
  <body class="design-stitch{% if lpKey or lp or hideServiceAreas or exemple or hasHeroVideo %} conversion-page{% endif %}" data-page="{{ pageKey | default('index') }}" data-gtm-id="{{ site.gtmId }}">
    {% include "header.njk" %}

    <main id="main">
      {{ content | safe }}
    </main>

    {% set showServiceAreas = true %}
    {% if pageKey in ['merci', 'mentions-legales', 'confidentialite', 'cookies', '404'] %}
      {% set showServiceAreas = false %}
    {% endif %}
    {% if page and page.url and '/blog/' in page.url %}
      {% set showServiceAreas = false %}
    {% endif %}
    {% if hideServiceAreas %}
      {% set showServiceAreas = false %}
    {% endif %}
    {% if showServiceAreas %}
      {% include "service-areas-block.njk" %}
    {% endif %}

    {% if page and page.url %}
      {% set moneyPrefixes = [
        '/',
        '/garage-ivry-sur-seine/',
        '/diagnostic/',
        '/mecanique/',
        '/carrosserie/',
        '/pare-brise/',
        '/entretien/',
        '/freins/',
        '/pneumatiques/',
        '/vidange/',
        '/tarifs/',
        '/contact/',
        '/vitry-sur-seine/',
        '/villejuif/',
        '/charenton-le-pont/',
        '/paris-13/',
        '/alfortville/',
        '/maisons-alfort/',
        '/kremlin-bicetre/',
        '/revision-auto-val-de-marne/',
        '/equipe/',
        '/processus/',
        '/blog/'
      ] %}
      {% set showConversionHub = false %}
      {% for prefix in moneyPrefixes %}
        {% if prefix in page.url %}
          {% set showConversionHub = true %}
        {% endif %}
      {% endfor %}
      {% if showConversionHub and pageKey != 'contact' and pageKey != 'merci' and not lpKey and not lp and not hideServiceAreas %}
        {% include "conversion-hub.njk" %}
      {% endif %}
    {% endif %}

    {% if pageKey != 'contact' and pageKey != 'merci' and not lpKey and not lp and not hideServiceAreas %}
      {% include "lead-strip.njk" %}
    {% endif %}

    {% include "footer.njk" %}
    {% include "floating-whatsapp.njk" %}
    {% if pageKey not in ['404', 'mentions-legales', 'confidentialite', 'cookies'] %}
      {% include "cta-sticky-call.njk" %}
    {% endif %}

    <script src="{{ '/assets/js/main.js' | cacheBust }}" defer></script>
    {% if scripts and scripts.mobileOptimizer == false %}{% else %}
    <script src="{{ '/assets/js/mobile-optimizer.js' | cacheBust }}" defer></script>
    {% endif %}
    <script src="{{ '/assets/js/cookies.js' | cacheBust }}" defer></script>
    {% if hasHeroVideo %}
    <script src="{{ '/assets/js/video-lazy.js' | cacheBust }}" defer></script>
    {% endif %}
    {% if scripts and scripts.effects == true %}
    <script>
      (function(){if('requestIdleCallback' in window){requestIdleCallback(function(){var s=document.createElement('script');s.src='/assets/js/futuristic-effects.js';s.defer=true;document.body.appendChild(s);});}else{var s=document.createElement('script');s.src='/assets/js/futuristic-effects.js';s.defer=true;document.body.appendChild(s);}})();
    </script>
    {% endif %}
  </body>
</html>
