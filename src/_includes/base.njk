<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes, viewport-fit=cover" />
    <meta name="description" content="{{ description | default(site.description or 'Garage automobile RED-K MOTORS à Ivry-sur-Seine. Mécanique, carrosserie, entretien et pneumatiques.') }}" />
    <meta name="author" content="{{ site.name }}" />
    <meta name="robots" content="{{ robots | default('index, follow') }}" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="{{ ogType | default('website') }}" />
    <meta property="og:url" content="{{ site.url }}{{ page.url | default('/') | replace('/index.html','/') }}" />
    <meta property="og:site_name" content="Garage Automobile {{ site.name }}" />
    <meta property="og:locale" content="{{ site.locale }}" />
    <meta property="og:title" content="{{ ogTitle | default(title) | default(site.name) }}" />
    <meta property="og:description" content="{{ ogDescription | default(description) | default(site.description) }}" />
    <meta property="og:image" content="{{ ogImage | default(site.ogImage) }}" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="{{ site.name }} - Garage mécanique et carrosserie Île-de-France" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="{{ twitterTitle | default(ogTitle) | default(title) | default(site.name) }}" />
    <meta name="twitter:description" content="{{ twitterDescription | default(ogDescription) | default(description) | default(site.description) }}" />
    <meta name="twitter:image" content="{{ ogImage | default(site.ogImage) }}" />
    <meta name="twitter:image:alt" content="{{ site.name }} - Garage mécanique et carrosserie Île-de-France" />

    <!-- Favicon + PWA -->
    <link rel="icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <title>{{ title | default(site.name) }}</title>
    <link rel="canonical" href="{{ site.url }}{{ page.url | default('/') | replace('/index.html','/') }}" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&family=Open+Sans:wght@400;600&display=swap" /></noscript>
    <link rel="preload" href="/assets/css/styles.css?v=2" as="style" />
    <link rel="preload" href="/assets/js/main.js" as="script" />
    <link rel="stylesheet" href="/assets/css/styles.css?v=2" />

    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="theme-color" content="#0b0b0f" />
    <meta name="msapplication-TileColor" content="#0b0b0f" />

    <!-- GTM chargé uniquement après consentement cookies (voir cookies.js) -->

    <!-- JSON-LD global (WebSite + AutoRepair + WebPage, une seule injection par page) -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "@id": "{{ site.url }}/#website",
          "name": "{{ site.name }}",
          "url": "{{ site.url }}",
          "description": "{{ site.description | default('Garage automobile à Ivry-sur-Seine') }}",
          "publisher": { "@id": "https://redk-motors.me/#business" },
          "inLanguage": "fr-FR",
          "potentialAction": {
            "@type": "SearchAction",
            "target": {
              "@type": "EntryPoint",
              "urlTemplate": "https://www.google.com/search?q=site:redk-motors.me+{search_term_string}"
            },
            "query-input": "required name=search_term_string"
          }
        },
        {
          "@type": "WebPage",
          "@id": "{{ site.url }}{{ page.url | default('/') | replace('/index.html','/') }}#webpage",
          "url": "{{ site.url }}{{ page.url | default('/') | replace('/index.html','/') }}",
          "name": "{{ title | default(site.name) }}",
          "description": "{{ description | default(site.description) }}",
          "isPartOf": { "@id": "{{ site.url }}/#website" },
          "about": { "@id": "https://redk-motors.me/#business" },
          "inLanguage": "fr-FR",
          "speakable": {
            "@type": "SpeakableSpecification",
            "cssSelector": ["h1", "h2", ".hero__desc", ".promesse__title", "meta[name='description']"]
          }
        },
        {{ (localBusinessSchema or localBusiness.schema) | json | safe }}
      ]
    }
    </script>

    {% if breadcrumb %}
    <!-- Breadcrumb Schema -->
    <script type="application/ld+json">
    {{ breadcrumb | json | safe }}
    </script>
    {% endif %}

    {% if faqSchema %}
    <!-- FAQ Schema -->
    <script type="application/ld+json">
    {{ faqSchema | json | safe }}
    </script>
    {% endif %}

    {% if articleSchema %}
    <!-- Article Schema (BlogPosting) -->
    <script type="application/ld+json">
    {{ articleSchema | json | safe }}
    </script>
    {% endif %}

    {% if localServiceSchema %}
    <!-- JSON-LD Service (zone desservie) -->
    <script type="application/ld+json">
    {{ localServiceSchema | json | safe }}
    </script>
    {% endif %}
  </head>
  <body data-page="{{ pageKey | default('index') }}" data-gtm-id="{{ site.gtmId }}">
    {% include "offer-banner.njk" %}
    {% include "header.njk" %}

    <main id="main">
      {{ content | safe }}
    </main>

    {% include "footer.njk" %}
    {% include "floating-whatsapp.njk" %}
    {% include "cta-sticky-call.njk" %}

    <script src="/assets/js/main.js" defer></script>
    {% if scripts and scripts.mobileOptimizer == false %}{% else %}
    <script src="/assets/js/mobile-optimizer.js" defer></script>
    {% endif %}
    <script src="/assets/js/cookies.js" defer></script>
    {% if hasHeroVideo or not (scripts and scripts.video == false) %}
    <script src="/assets/js/video-lazy.js" defer></script>
    {% endif %}
    {% if scripts and scripts.effects == true %}
    <script>
      (function(){if('requestIdleCallback' in window){requestIdleCallback(function(){var s=document.createElement('script');s.src='/assets/js/futuristic-effects.js';s.defer=true;document.body.appendChild(s);});}else{var s=document.createElement('script');s.src='/assets/js/futuristic-effects.js';s.defer=true;document.body.appendChild(s);}})();
    </script>
    {% endif %}
  </body>
</html>
