{# hubLayout: "feature" | "cards" | "catalog" #}
{% if (hubGuides and hubGuides.length) or hubCatalogGroups %}
<section
  class="price-examples-hub price-examples-hub--{{ hubLayout | default('cards') }}{% if hubGuides and hubGuides.length == 1 %} price-examples-hub--solo{% endif %}"
  aria-labelledby="price-examples-hub-title"
>
  <div class="container">
    <header class="conversion-section-head conversion-section-head--light">
      <p class="section-kicker">{{ hubKicker | default("Exemples concrets") }}</p>
      <h2 class="conversion-section-head__title" id="price-examples-hub-title">
        {{ hubTitle | default("Combien ça coûte ?") }}
      </h2>
      {% if hubLead %}
      <p class="price-examples-hub__lead">{{ hubLead }}</p>
      {% endif %}
    </header>

    {% if hubLayout == "catalog" and hubCatalogGroups %}
      <div class="price-examples-hub__catalog">
        {% for group in hubCatalogGroups %}
        <section class="price-examples-hub__group" aria-labelledby="price-hub-group-{{ group.id }}">
          <h3 class="price-examples-hub__group-title" id="price-hub-group-{{ group.id }}">{{ group.label }}</h3>
          <ul class="price-examples-hub__list">
            {% for guide in group.guides %}
            <li>
              <a
                class="price-examples-hub__row-link"
                href="{{ guide.url }}"
                data-track="click_price_example"
                data-track-pos="{{ hubTrack | default('price_examples_hub') }}"
                data-track-label="{{ guide.slug }}"
              >
                <span class="price-examples-hub__row-main">
                  <span class="price-examples-hub__label">{{ guide.hubLabel }}</span>
                  <span class="price-examples-hub__hook">{{ guide.hook }}</span>
                </span>
                <span class="price-examples-hub__row-prices">
                  <span class="price-examples-hub__row-pill price-examples-hub__row-pill--network">{{ guide.networkPrice }}</span>
                  <span class="price-examples-hub__row-pill price-examples-hub__row-pill--redk">{{ guide.usp }}</span>
                </span>
                <span class="price-examples-hub__row-arrow" aria-hidden="true">→</span>
              </a>
            </li>
            {% endfor %}
          </ul>
        </section>
        {% endfor %}
      </div>
      <p class="price-examples-hub__footer">
        Modèle précis (Clio, 208, Golf…) : chaque guide renvoie vers des exemples par véhicule.
      </p>

    {% elif hubLayout == "feature" and hubGuides.length == 1 %}
      {% set guide = hubGuides[0] %}
      <a
        class="price-examples-hub__feature"
        href="{{ guide.url }}"
        data-track="click_price_example"
        data-track-pos="{{ hubTrack | default('price_examples_hub') }}"
        data-track-label="{{ guide.slug }}"
      >
        <p class="price-examples-hub__feature-hook">{{ guide.hook }}</p>
        <div class="price-examples-hub__feature-compare">
          <div class="price-examples-hub__feature-col">
            <span class="price-examples-hub__feature-label">Grand réseau</span>
            <span class="price-examples-hub__feature-value">{{ guide.networkPrice }}</span>
          </div>
          <div class="price-examples-hub__feature-col price-examples-hub__feature-col--redk">
            <span class="price-examples-hub__feature-label">RED-K MOTORS</span>
            <span class="price-examples-hub__feature-value">{{ guide.hubRedkLine }}</span>
            <span class="price-examples-hub__feature-usp">{{ guide.usp }}</span>
          </div>
        </div>
        <span class="price-examples-hub__feature-cta">{{ guide.cta }} →</span>
      </a>

    {% else %}
      <ul class="price-examples-hub__grid">
        {% for guide in hubGuides %}
        <li>
          <a
            class="price-examples-hub__card"
            href="{{ guide.url }}"
            data-track="click_price_example"
            data-track-pos="{{ hubTrack | default('price_examples_hub') }}"
            data-track-label="{{ guide.slug }}"
          >
            <span class="price-examples-hub__label">{{ guide.hubLabel }}</span>
            <p class="price-examples-hub__hook">{{ guide.hook }}</p>
            <div class="price-examples-hub__card-prices">
              <span class="price-examples-hub__mini">
                <span class="price-examples-hub__mini-label">Réseau</span>
                <span class="price-examples-hub__mini-value">{{ guide.networkPrice }}</span>
              </span>
              <span class="price-examples-hub__mini price-examples-hub__mini--redk">
                <span class="price-examples-hub__mini-label">RED-K</span>
                <span class="price-examples-hub__mini-value">{{ guide.hubRedkLine }}</span>
              </span>
            </div>
            <span class="price-examples-hub__usp">{{ guide.usp }}</span>
            <span class="price-examples-hub__cta">{{ guide.cta }} →</span>
          </a>
        </li>
        {% endfor %}
      </ul>
    {% endif %}
  </div>
</section>
{% endif %}
