<section class="cta-block" aria-labelledby="cta-block-title" data-animate="slide-up">
  <div class="container cta-block__inner">
    <h2 id="cta-block-title" class="cta-block__title">Un problème ? On vous répond tout de suite.</h2>
    <p class="cta-block__sub">Ouvert du lundi au samedi, 10h-20h. Appelez ou envoyez un message.</p>
    <div class="cta-block__buttons">
      <a href="tel:{{ site.phone }}" class="btn btn--primary cta-block__btn" data-track="click_call">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 012.12 4.18 2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.362 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.338 1.85.573 2.81.7A2 2 0 0122 16.92z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Appeler {{ site.phoneDisplay }}
      </a>
      <a href="{{ site.whatsappUrl }}" class="btn btn--secondary cta-block__btn" target="_blank" rel="noopener noreferrer" data-track="click_whatsapp">
        WhatsApp
      </a>
    </div>
  </div>
</section>
