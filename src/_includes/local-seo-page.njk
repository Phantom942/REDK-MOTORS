{% set heroActions %}
<a class="btn btn--primary" href="tel:{{ site.phone }}" data-track="click_call" data-track-pos="hero_local">Appeler {{ site.phoneDisplayCompact | default(site.phoneDisplay) }}</a>
<a class="btn btn--secondary" href="{{ site.whatsappUrl }}" target="_blank" rel="noopener noreferrer" data-track="click_whatsapp" data-track-pos="hero_local">WhatsApp</a>
{% endset %}
{% set heroClass = "hero--subpage hero--conversion" %}
{% set heroAria = pageKey ~ "-hero-title" %}
{% set heroTitle = h1 %}
{% set heroKicker = heroKickerText %}
{% set heroDesc = heroDescription %}
{% set videoSrc = "hero.mp4" %}
{% include "hero-video.njk" %}

{% include "lp-trust-bar.njk" %}

{% if introHeading or introText %}
<section class="service-focus service-focus--compact" aria-labelledby="local-intro-{{ pageKey }}">
  <div class="container service-focus__inner">
    <div>
      {% if introHeading %}<h2 id="local-intro-{{ pageKey }}">{{ introHeading }}</h2>{% endif %}
      {% if introText %}<p>{{ introText }}</p>{% endif %}
    </div>
  </div>
</section>
{% endif %}

{% if not lp %}
  {% set lp = pageKey | localSeoEnhancements %}
{% endif %}
{% set lpId = lpId | default(pageKey) %}

{% set contactTitle = "Contactez-nous" %}
{% set contactLead = introText | default("Garage à Ivry-sur-Seine — devis gratuit, intervention après validation.") %}
{% include "conversion-contact.njk" %}

{% if lp and lp.seoParagraphs and lp.seoParagraphs.length %}
  {% include "lp-seo-intro.njk" %}
{% endif %}

{% set pageSymptoms = symptoms | default(lp.symptoms) %}
{% if pageSymptoms and pageSymptoms.length %}
  {% set symptoms = pageSymptoms %}
  {% set symptomsSectionId = "local-symptoms-" ~ pageKey %}
  {% include "lp-symptoms.njk" %}
{% endif %}

{% if lp and lp.highlights and lp.highlights.length %}
<section class="promesse promesse--highlights" aria-labelledby="local-highlights-{{ pageKey }}">
  <div class="container">
    {% set sectionKicker = "Notre méthode" %}
    {% set sectionTitle = "Pourquoi passer par RED-K MOTORS" %}
    {% set sectionHeadId = "local-highlights-" ~ pageKey %}
    {% include "conversion-section-head.njk" %}
    <div class="promesse__grid">
      {% for highlight in lp.highlights %}
      <div class="promesse__item">
        <span class="promesse__icon" aria-hidden="true">✓</span>
        <div>
          <h3>{{ highlight }}</h3>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{% include "local-seo-services.njk" %}

{% include "local-seo-zone.njk" %}

{% set moneyPages = pageKey | localSeoMoneyPages %}
{% if moneyPages.length %}
<section class="conversion-services conversion-services--money" aria-labelledby="local-money-{{ pageKey }}">
  <div class="container">
    {% set sectionKicker = "Pages utiles" %}
    {% set sectionTitle = "Prestations principales" %}
    {% set sectionHeadId = "local-money-" ~ pageKey %}
    {% include "conversion-section-head.njk" %}
    <ul class="conversion-services__list">
      {% for page in moneyPages %}
      <li><a href="{{ page.url }}" class="conversion-services__link">{{ page.title }}</a></li>
      {% endfor %}
    </ul>
  </div>
</section>
{% endif %}

{% set tarifsTeaserTrack = pageKey ~ "_tarifs" %}
{% include "conversion-tarifs-teaser.njk" %}

{% set reviewKey = pageKey | localSeoReviewKey %}
{% set pageReviews = reviewKey | resolvePageReviews(googleReviews, 2) %}
{% if pageReviews and pageReviews.length %}
  {% include "reviews-page-block.njk" %}
{% endif %}

{% include "conversion-services-nav.njk" %}

{% set lpId = lpId | default(pageKey) %}
{% include "lp-related-services.njk" %}

{% if lp and lp.seoFooter %}
  {% include "lp-seo-footer.njk" %}
{% endif %}

{% set pageFaqItems = faqs | pageFaqs(faqSchema) %}
{% if pageFaqItems.length %}
<section class="faq conversion-faq" aria-labelledby="faq-{{ pageKey }}">
  <div class="container faq__inner faq__inner--compact">
    {% set sectionKicker = "FAQ" %}
    {% set sectionTitle = faqHeading | default("Questions fréquentes") %}
    {% set sectionHeadId = "faq-" ~ pageKey %}
    {% include "conversion-section-head.njk" %}
    <div class="faq__list" data-accordion>
      {% for faq in pageFaqItems %}
      <article class="faq__item">
        <button class="faq__question" type="button" aria-expanded="false">{{ faq.question }}</button>
        <div class="faq__answer" hidden>
          <p>{{ faq.answer }}</p>
        </div>
      </article>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{% set contactVariant = 'footer' %}
{% set contactTitle = 'Un devis ? Un RDV ?' %}
{% set contactLead = 'On vous répond rapidement en journée.' %}
{% include "conversion-contact.njk" %}
