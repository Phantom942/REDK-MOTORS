    <a
      href="{{ site.googleReviews.mapsPlaceUrl }}"
      class="conversion-map__open"
      target="_blank"
      rel="noopener noreferrer"
      data-track="click_maps"
      data-track-pos="contact_map"
    >
      <span class="conversion-map__pin" aria-hidden="true">📍</span>
      <span class="conversion-map__address">{{ site.addressFull }}</span>
      <span class="conversion-map__cta">Ouvrir le plan dans Google Maps →</span>
    </a>
    <p class="conversion-map__routes">
      <a href="{{ site.wazeUrl }}" target="_blank" rel="noopener noreferrer" data-track="click_waze" data-track-pos="contact_map">Itinéraire Waze</a>
      ·
      <a href="{{ site.googleReviews.mapsPlaceUrl }}" target="_blank" rel="noopener noreferrer">Google Maps</a>
    </p>
  </div>
</section>

{% include "conversion-services-nav.njk" %}

