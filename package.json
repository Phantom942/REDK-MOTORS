{
  "name": "redk-motors",
  "version": "2.0.0",
  "description": "Site garage RED-K MOTORS - Ivry-sur-Seine",
  "scripts": {
    "check:hours": "node scripts/check-hours.js",
    "build": "npm run check:hours && node -e \"require('fs').rmSync('_site',{recursive:true,force:true});\" && eleventy && node scripts/minify.js",
    "serve": "eleventy --serve",
    "dev": "eleventy --serve",
    "favicon": "node scripts/generate-favicons.js",
    "og-image": "node scripts/generate-og-image.js",
    "ads:generate": "node scripts/generate-ad-videos.js",
    "google:place-id": "node scripts/resolve-google-place-id.js"
  },
  "keywords": [
    "eleventy",
    "static-site",
    "garage"
  ],
  "author": "RED-K MOTORS",
  "license": "UNLICENSED",
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "clean-css": "^5.3.3",
    "sharp": "^0.33.5",
    "sharp-ico": "^0.1.5"
  }
}
